# Environment variables for the regulatory-risk-system backend.
# Copy to `.env` and adjust.

# ──────── Application ────────
APP_VERSION=2.0.0
LOG_LEVEL=INFO
JSON_LOGS=false

# ──────── Database ────────
# Dev default: SQLite. Prod: PostgreSQL.
# DATABASE_URL=sqlite+aiosqlite:///./data/regulatory_risk.db
DATABASE_URL=postgresql+asyncpg://risk:risk@postgres:5432/risk

# ──────── LLM ────────
LLM_MODE=mock
LLM_API_KEY=
LLM_BASE_URL=http://litellm:4000/v1
LLM_MODEL=qwen-plus

# ──────── Security ────────
SECRET_KEY=change-me-in-production
JWT_ACCESS_TTL_MIN=1440
WS_TICKET_TTL_SEC=30

# ──────── Data ────────
DATA_MODE=local   # local | mock
COMPETITION_DATA_DIR=./data/competition

# ──────── Memory (Phase 5) ────────
MEMORY_SERVICE_BASE_URL=http://memoflux:8020

# ──────── Redis (Phase 4) ────────
REDIS_URL=redis://redis:6379/0

# ──────── Feature flags ────────
ENABLE_RUNTIME_EXTENSIONS=true
ENABLE_WEBSOCKET=true
ENABLE_RATE_LIMIT=false
ENABLE_MOCK_DATA_FALLBACK=true
ENABLE_MEMO_FLUX=false
