# LLM 配置（Demo 模式下可不填）
LLM_MODE=mock
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=qwen-plus

# 切换到真实 LLM（OpenAI-Compatible API）示例：
# LLM_MODE=real
# LLM_API_KEY=sk-xxxxx
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus           # 或 deepseek-chat / qwen3-235b-instruct

# 数据库（默认 SQLite，生产可改 PostgreSQL）
# DATABASE_URL=postgresql+asyncpg://user:pwd@localhost:5432/regulatory_risk
DATABASE_URL=sqlite+aiosqlite:///data/regulatory_risk.db
